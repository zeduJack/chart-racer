{
  "name": "chart-racer",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3003",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npx playwright test",
    "test:ui": "npx playwright test tests/visual/editor-ui.spec.ts",
    "test:stills": "npx playwright test tests/visual/animation-frames.spec.ts",
    "remotion:studio": "npx remotion studio src/remotion/index.ts",
    "remotion:render": "npx remotion render src/remotion/index.ts BarChartRace",
    "remotion:still": "npx remotion still src/remotion/index.ts BarChartRace",
    "chart-racer": "npx tsx src/cli/index.ts",
    "render": "npx tsx src/cli/index.ts render",
    "render:reels": "npx tsx src/cli/index.ts render --format 9:16",
    "render:square": "npx tsx src/cli/index.ts render --format 1:1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@remotion/cli": "4.0.441",
    "@remotion/player": "4.0.441",
